# Copy to .env and fill these values from the official Trading 212 API docs.
T212_API_KEY=
T212_API_SECRET=
T212_BASE_URL=https://demo.trading212.com/api/v0
T212_TIMEOUT_SECONDS=10
T212_TRANSPORT=streamable-http
T212_HOST=127.0.0.1
T212_PORT=8000
T212_STREAMABLE_HTTP_PATH=/mcp
T212_AUTH_TOKEN=change-me
T212_ENFORCE_HTTP_BEARER_AUTH=true
T212_RATE_LIMIT_REQUESTS=30
T212_RATE_LIMIT_WINDOW_SECONDS=60
